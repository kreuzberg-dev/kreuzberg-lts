{
  "name": "@kreuzberg/core",
  "version": "4.10.2",
  "description": "Kreuzberg document intelligence library — core types and utilities for text extraction from 88+ formats",
  "keywords": [
    "document-extraction",
    "document-intelligence",
    "text-extraction",
    "pdf",
    "ocr",
    "docx",
    "office-documents",
    "rust",
    "nlp",
    "rag",
    "metadata-extraction",
    "kreuzberg"
  ],
  "author": {
    "name": "Na'aman Hirschfeld",
    "email": "naaman@kreuzberg.dev",
    "url": "https://kreuzberg.dev"
  },
  "homepage": "https://kreuzberg.dev",
  "bugs": {
    "url": "https://github.com/kreuzberg-dev/kreuzberg-lts/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kreuzberg-dev/kreuzberg-lts.git"
  },
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.mjs",
      "require": "./dist/types/index.js"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "import": "./dist/utils/index.mjs",
      "require": "./dist/utils/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "engines": {
    "node": ">= 22"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:watch": "vitest --watch"
  },
  "dependencies": {
    "@kreuzberg/node": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsup": "^8.5.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
